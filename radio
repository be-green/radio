GREEN=$'\033[32m'
YELLOW=$'\033[33m'
MAGENTA=$'\033[35m'
WHITE=$'\033[37m'
BLUE=$'\033[34m'

# ---------------------------------------------------------------------------
# Utility functions
# ---------------------------------------------------------------------------
update_terminal_size() {
    TERM_WIDTH=$(tput cols 2>/dev/null) || TERM_WIDTH=80
    TERM_HEIGHT=$(tput lines 2>/dev/null) || TERM_HEIGHT=24
}

get_terminal_width() {
    echo "$TERM_WIDTH"
}

get_terminal_height() {
    echo "$TERM_HEIGHT"
}

hide_cursor() { printf '\033[?25l'; }
show_cursor() { printf '\033[?25h'; }
clear_screen() { printf '\033[2J\033[H'; }
move_to() { printf -v _f '\033[%d;%dH' "$1" "$2"; OUT+="$_f"; }

draw_horizontal_line() {
    local width="$1"
    local i
    local line=""
    for ((i = 0; i < width; i++)); do
        line+="─"
    done
    printf '%s' "$line"
}

erase_below() {
    local row=$1
    while [[ $row -lt $TERM_HEIGHT ]]; do
        OUT+=$'\033['"${row};1H"$'\033[K'
        ((row++))
    done
}

build_category_list() {
    CATEGORY_LIST=()
    CATEGORY_COUNTS=()
    local i seen count
    for i in "${!STATION_CATEGORIES[@]}"; do
        seen=0
        for existing in "${CATEGORY_LIST[@]}"; do
            if [[ "$existing" == "${STATION_CATEGORIES[$i]}" ]]; then
                seen=1
                break
            fi
        done
        if [[ $seen -eq 0 ]]; then
            CATEGORY_LIST+=("${STATION_CATEGORIES[$i]}")
            count=0
            for k in "${!STATION_CATEGORIES[@]}"; do
                if [[ "${STATION_CATEGORIES[$k]}" == "${STATION_CATEGORIES[$i]}" ]]; then
                    ((count++))
                fi
            done
            CATEGORY_COUNTS+=("$count")
        fi
    done
}

expand_current_category() {
    EXPANDED_STATIONS=()
    local category="${CATEGORY_LIST[$CATEGORY_CURSOR]}"
    local i
    for i in "${!STATION_CATEGORIES[@]}"; do
        if [[ "${STATION_CATEGORIES[$i]}" == "$category" ]]; then
            EXPANDED_STATIONS+=("$i")
        fi
    done
}


# ---------------------------------------------------------------------------
# Volume control (macOS system volume via osascript)
# ---------------------------------------------------------------------------
get_volume() {
    VOLUME=$(osascript -e "output volume of (get volume settings)" 2>/dev/null)
    if [[ -z "$VOLUME" ]] || [[ "$VOLUME" == "missing value" ]]; then
        VOLUME=50
    fi
}

adjust_volume() {
    local delta=$1
    local new_vol=$((VOLUME + delta))
    if [[ $new_vol -lt 0 ]]; then new_vol=0; fi
    if [[ $new_vol -gt 100 ]]; then new_vol=100; fi
    osascript -e "set volume output volume $new_vol" 2>/dev/null &
    VOLUME=$new_vol
}

# ---------------------------------------------------------------------------
# Waveform
# ---------------------------------------------------------------------------
read_waveform() {
    WAVE_DISPLAY_TOP=""
    WAVE_DISPLAY_BOT=""
    if [[ -z "$WAVE_PID" ]] || [[ $VU_WIDTH -eq 0 ]]; then
        return
    fi
    if [[ ! -s "$DISPLAY_FILE" ]]; then
        return
    fi
    local content
    content=$(<"$DISPLAY_FILE") 2>/dev/null || return
    if [[ -z "$content" ]]; then
        return
    fi
    local top_line="${content%%$'\n'*}"
    local bot_line="${content#*$'\n'}"
    if [[ "$bot_line" == "$content" ]]; then
        bot_line=""
    fi
    local top_len=${#top_line}
    if [[ $top_len -gt $VU_WIDTH ]]; then
        top_line="${top_line:$((top_len - VU_WIDTH))}"
    fi
    local bot_len=${#bot_line}
    if [[ $bot_len -gt $VU_WIDTH ]]; then
        bot_line="${bot_line:$((bot_len - VU_WIDTH))}"
    fi
    WAVE_DISPLAY_TOP="${GREEN}${top_line}${RESET}"
    WAVE_DISPLAY_BOT="${GREEN}${bot_line}${RESET}"
}

calculate_vu_width() {
    if [[ $TERM_WIDTH -lt 55 ]]; then
        VU_WIDTH=0
        return
    fi
    VU_WIDTH=$((TERM_WIDTH - WAVE_COL))
    if [[ $VU_WIDTH -lt 5 ]]; then
        VU_WIDTH=5
    elif [[ $VU_WIDTH -gt 200 ]]; then
        VU_WIDTH=200
    fi
}

# ---------------------------------------------------------------------------
# Playback (two ffmpeg processes: audiotoolbox for audio, u8 PCM for waveform)
# ---------------------------------------------------------------------------
stop_playback() {
    if [[ -n "$CURRENT_PID" ]] && kill -0 "$CURRENT_PID" 2>/dev/null; then
        if [[ $PAUSED -eq 1 ]]; then
            kill -CONT "$CURRENT_PID" 2>/dev/null
        fi
        kill "$CURRENT_PID" 2>/dev/null
    fi
    if [[ -n "$WAVE_PID" ]] && kill -0 "$WAVE_PID" 2>/dev/null; then
        if [[ $PAUSED -eq 1 ]]; then
            kill -CONT "$WAVE_PID" 2>/dev/null
        fi
        kill "$WAVE_PID" 2>/dev/null
    fi
    if [[ -n "$CURRENT_PID" ]] || [[ -n "$WAVE_PID" ]]; then
        sleep 0.05
    fi
    CURRENT_PID=""
    WAVE_PID=""
    RECONNECT_ATTEMPTS=0
    PAUSED=0
    WAVE_DISPLAY_TOP=""
    WAVE_DISPLAY_BOT=""
    if [[ -n "$DISPLAY_FILE" ]]; then
        rm -f "$DISPLAY_FILE" "${DISPLAY_FILE}.tmp" "${DISPLAY_FILE}.pid" 2>/dev/null
    fi
}

toggle_pause() {
    if [[ -z "$CURRENT_PID" ]] || ! kill -0 "$CURRENT_PID" 2>/dev/null; then
        return
    fi
    if [[ $PAUSED -eq 0 ]]; then
        kill -STOP "$CURRENT_PID" 2>/dev/null
        if [[ -n "$WAVE_PID" ]] && kill -0 "$WAVE_PID" 2>/dev/null; then
            kill -STOP "$WAVE_PID" 2>/dev/null
        fi
        PAUSED=1
    else
        kill -CONT "$CURRENT_PID" 2>/dev/null
        if [[ -n "$WAVE_PID" ]] && kill -0 "$WAVE_PID" 2>/dev/null; then
            kill -CONT "$WAVE_PID" 2>/dev/null
        fi
        PAUSED=0
    fi
}

start_playback() {
    local index="$1"
    stop_playback
    local url="${STATION_URLS[$index]}"
    local pid_file="${DISPLAY_FILE}.pid"
    sh -c 'printf "%d" "$$" > "$1"; exec ffmpeg -loglevel quiet -nostdin -i "$2" -f audiotoolbox - -ac 1 -ar 8000 -f u8 pipe:1' \
        _ "$pid_file" "$url" </dev/null 2>/dev/null | \
        perl "$WAVE_SCRIPT" "$DISPLAY_FILE" >/dev/null 2>&1 &
    WAVE_PID=$!
    disown
    sleep 0.05
    [[ -s "$pid_file" ]] && CURRENT_PID=$(<"$pid_file")
    rm -f "$pid_file" 2>/dev/null
    CURRENT_STATION_INDEX="$index"
    RECONNECT_ATTEMPTS=0
}

check_playback() {
    if [[ -n "$CURRENT_PID" ]] && ! kill -0 "$CURRENT_PID" 2>/dev/null; then
        if [[ -n "$WAVE_PID" ]] && kill -0 "$WAVE_PID" 2>/dev/null; then
            kill "$WAVE_PID" 2>/dev/null
            sleep 0.05
            WAVE_PID=""
        fi
        if [[ $RECONNECT_ATTEMPTS -lt $MAX_RECONNECT ]]; then
            ((RECONNECT_ATTEMPTS++))
            local url="${STATION_URLS[$CURRENT_STATION_INDEX]}"
            local pid_file="${DISPLAY_FILE}.pid"
            sh -c 'printf "%d" "$$" > "$1"; exec ffmpeg -loglevel quiet -nostdin -i "$2" -f audiotoolbox - -ac 1 -ar 8000 -f u8 pipe:1' \
                _ "$pid_file" "$url" </dev/null 2>/dev/null | \
                perl "$WAVE_SCRIPT" "$DISPLAY_FILE" >/dev/null 2>&1 &
            WAVE_PID=$!
            disown
            sleep 0.05
            [[ -s "$pid_file" ]] && CURRENT_PID=$(<"$pid_file")
            rm -f "$pid_file" 2>/dev/null
        else
            CURRENT_PID=""
            WAVE_PID=""
            CURRENT_STATION_INDEX=""
            WAVE_DISPLAY_TOP=""
            WAVE_DISPLAY_BOT=""
        fi
    fi
}

# ---------------------------------------------------------------------------
# Rendering (flicker-free: move_to + erase-to-end-of-line, no clear_screen)
# ---------------------------------------------------------------------------
render_header() {
    local width=$TERM_WIDTH
    move_to 1 1

    local title=" RADIO"
    local vol_info=""
    if [[ -n "$VOLUME" ]]; then
        vol_info="  Vol: ${VOLUME}"
    fi
    local now_playing=""
    if [[ -n "$CURRENT_STATION_INDEX" ]]; then
        local pause_indicator=""
        if [[ $PAUSED -eq 1 ]]; then
            pause_indicator=" [paused]"
        fi
        now_playing="  ${STATION_NAMES[$CURRENT_STATION_INDEX]}${pause_indicator} "
    fi

    local left="${title}${vol_info}"
    local right="$now_playing"
    local padding=$((width - ${#left} - ${#right}))
    if [[ $padding -lt 0 ]]; then padding=0; fi

    printf -v _f '%s%s%*s' "${REVERSE}${BOLD}${left}" "" "$padding" ""
    OUT+="$_f"
    if [[ -n "$right" ]]; then
        OUT+="${GREEN}${REVERSE}${right}"
    fi
    OUT+="${RESET}"$'\033[K'

    RENDER_ROW=3
}

render_footer() {
    local width=$TERM_WIDTH
    local height=$TERM_HEIGHT
    move_to "$height" 1

    local hints=" j/k:nav  enter:select  b:back  s:stop  p:pause  +/-:vol  q:quit"

    local padding=$((width - ${#hints}))
    if [[ $padding -lt 0 ]]; then padding=0; fi

    printf -v _f '%s%s%*s%s' "${REVERSE}${DIM}" "$hints" "$padding" "" "${RESET}"
    OUT+="$_f"
}

render_list() {
    local cat_idx
    for cat_idx in "${!CATEGORY_LIST[@]}"; do
        local category="${CATEGORY_LIST[$cat_idx]}"
        local station_count="${CATEGORY_COUNTS[$cat_idx]}"
        local is_current_cat=0
        if [[ $cat_idx -eq $CATEGORY_CURSOR ]]; then
            is_current_cat=1
        fi

        local expand_marker="▸"
        if [[ $is_current_cat -eq 1 ]]; then
            expand_marker="▾"
        fi

        move_to "$RENDER_ROW" 1
        if [[ $is_current_cat -eq 1 ]] && [[ $STATION_CURSOR -eq -1 ]]; then
            printf -v _f '  %s %s%s %-28s%s  %s%d%s' \
                "${CYAN}>${RESET}" \
                "${BOLD}${WHITE}" "$expand_marker" "$category" "${RESET}" \
                "${DIM}" "$station_count" "${RESET}"
            OUT+="$_f"$'\033[K'
        else
            printf -v _f '   %s %-28s  %s%d%s' \
                "$expand_marker" "$category" \
                "${DIM}" "$station_count" "${RESET}"
            OUT+="$_f"$'\033[K'
        fi
        ((RENDER_ROW++))

        if [[ $is_current_cat -eq 1 ]]; then
            local s_idx
            for s_idx in "${!EXPANDED_STATIONS[@]}"; do
                local station_idx="${EXPANDED_STATIONS[$s_idx]}"
                local name="${STATION_NAMES[$station_idx]}"
                local desc="${STATION_DESCS[$station_idx]}"
                local quality="${STATION_QUALITY[$station_idx]}"
                local playing_marker=""
                local is_playing=0

                if [[ "$station_idx" == "$CURRENT_STATION_INDEX" ]]; then
                    is_playing=1
                    if [[ $PAUSED -eq 1 ]]; then
                        playing_marker="${YELLOW} ▐▐${RESET}"
                    else
                        playing_marker="${GREEN} ▶${RESET}"
                    fi
                fi

                move_to "$RENDER_ROW" 1
                if [[ $s_idx -eq $STATION_CURSOR ]]; then
                    printf -v _f '    %s %s%-30s%s %s%-7s%s%s' \
                        "${CYAN}>${RESET}" \
                        "${BOLD}${WHITE}" "$name" "${RESET}" \
                        "${YELLOW}" "$quality" "${RESET}" \
                        "$playing_marker"
                    OUT+="$_f"$'\033[K'
                    if [[ $is_playing -eq 1 ]] && [[ -n "$WAVE_DISPLAY_TOP" ]]; then
                        printf -v _f '\033[%dG%s' "$WAVE_COL" "$WAVE_DISPLAY_TOP"
                        OUT+="$_f"
                    fi
                    ((RENDER_ROW++))
                    move_to "$RENDER_ROW" 1
                    printf -v _f '      %s%s%s' "${DIM}" "$desc" "${RESET}"
                    OUT+="$_f"$'\033[K'
                    if [[ $is_playing -eq 1 ]] && [[ -n "$WAVE_DISPLAY_BOT" ]]; then
                        printf -v _f '\033[%dG%s' "$WAVE_COL" "$WAVE_DISPLAY_BOT"
                        OUT+="$_f"
                    fi
                else
                    printf -v _f '     %-30s %s%-7s%s%s' \
                        "$name" \
                        "${DIM}" "$quality" "${RESET}" \
                        "$playing_marker"
                    OUT+="$_f"$'\033[K'
                    if [[ $is_playing -eq 1 ]] && [[ -n "$WAVE_DISPLAY_TOP" ]]; then
                        printf -v _f '\033[%dG%s' "$WAVE_COL" "$WAVE_DISPLAY_TOP"
                        OUT+="$_f"
                    fi
                    if [[ $is_playing -eq 1 ]] && [[ -n "$WAVE_DISPLAY_BOT" ]]; then
                        ((RENDER_ROW++))
                        move_to "$RENDER_ROW" 1
                        OUT+=$'\033[K'
                        printf -v _f '\033[%dG%s' "$WAVE_COL" "$WAVE_DISPLAY_BOT"
                        OUT+="$_f"
                    fi
                fi
                ((RENDER_ROW++))
            done
        fi
    done
}

render() {
    OUT=""
    ((FRAME_COUNT++))
    read_waveform

    RENDER_ROW=1
    render_header

    render_list

    erase_below "$RENDER_ROW"
    render_footer
    printf '%s' "$OUT"
}

# ---------------------------------------------------------------------------
# Input handling
# ---------------------------------------------------------------------------
KEY_RESULT=""

read_key() {
    local key seq read_exit
    IFS= read -rsn1 -t 1 key
    read_exit=$?

    if [[ $read_exit -ne 0 ]] && [[ -z "$key" ]]; then
        KEY_RESULT="TIMEOUT"
        return
    fi

    if [[ "$key" == $'\x1b' ]]; then
        IFS= read -rsn1 -t 1 seq
        if [[ "$seq" == "[" ]]; then
            IFS= read -rsn1 -t 1 seq
            case "$seq" in
                A) KEY_RESULT="UP"; return ;;
                B) KEY_RESULT="DOWN"; return ;;
                C) KEY_RESULT="RIGHT"; return ;;
                D) KEY_RESULT="LEFT"; return ;;
                Z) KEY_RESULT="BACK"; return ;;
            esac
        fi
        KEY_RESULT="ESCAPE"
        return
    fi

    case "$key" in
        k) KEY_RESULT="UP" ;;
        j) KEY_RESULT="DOWN" ;;
        q) KEY_RESULT="QUIT" ;;
        b) KEY_RESULT="BACK" ;;
        s) KEY_RESULT="STOP" ;;
        p) KEY_RESULT="PAUSE" ;;
        $'\t') KEY_RESULT="TAB" ;;
        +|=) KEY_RESULT="VOL_UP" ;;
        -) KEY_RESULT="VOL_DOWN" ;;
        ""|$'\n'|$'\r') KEY_RESULT="ENTER" ;;
        *) KEY_RESULT="OTHER" ;;
    esac
}

handle_input() {
    read_key
    local max_cat=$(( ${#CATEGORY_LIST[@]} - 1 ))
    local max_station=$(( ${#EXPANDED_STATIONS[@]} - 1 ))

    case "$KEY_RESULT" in
        UP)
            if [[ $STATION_CURSOR -gt 0 ]]; then
                ((STATION_CURSOR--))
            elif [[ $STATION_CURSOR -eq 0 ]]; then
                STATION_CURSOR=-1
            elif [[ $CATEGORY_CURSOR -gt 0 ]]; then
                ((CATEGORY_CURSOR--))
                expand_current_category
            fi
            ;;
        DOWN)
            if [[ $STATION_CURSOR -ge 0 ]]; then
                if [[ $STATION_CURSOR -lt $max_station ]]; then
                    ((STATION_CURSOR++))
                else
                    STATION_CURSOR=-1
                    if [[ $CATEGORY_CURSOR -lt $max_cat ]]; then
                        ((CATEGORY_CURSOR++))
                        expand_current_category
                    else
                        STATION_CURSOR=$max_station
                    fi
                fi
            elif [[ $CATEGORY_CURSOR -lt $max_cat ]]; then
                ((CATEGORY_CURSOR++))
                expand_current_category
            fi
            ;;
        TAB)
            if [[ $STATION_CURSOR -eq -1 ]]; then
                STATION_CURSOR=0
            elif [[ $STATION_CURSOR -lt $max_station ]]; then
                ((STATION_CURSOR++))
            else
                STATION_CURSOR=-1
            fi
            ;;
        ENTER)
            if [[ $STATION_CURSOR -eq -1 ]]; then
                start_playback "${EXPANDED_STATIONS[0]}"
            else
                start_playback "${EXPANDED_STATIONS[$STATION_CURSOR]}"
            fi
            ;;
        BACK)
            if [[ $STATION_CURSOR -ge 0 ]]; then
                STATION_CURSOR=-1
            fi
            ;;
        STOP)
            stop_playback
            CURRENT_STATION_INDEX=""
            ;;
        PAUSE)
            toggle_pause
            ;;
        VOL_UP)
            adjust_volume 5
            ;;
        VOL_DOWN)
            adjust_volume -5
            ;;
        TIMEOUT)
            ;;
        QUIT)
            return 1
            ;;
    esac
    return 0
}

# ---------------------------------------------------------------------------
# Cleanup
# ---------------------------------------------------------------------------
cleanup() {
    if [[ -n "$TIMER_PID" ]] && kill -0 "$TIMER_PID" 2>/dev/null; then
        kill "$TIMER_PID" 2>/dev/null
        wait "$TIMER_PID" 2>/dev/null
    fi
    TIMER_PID=""
    stop_playback
    show_cursor
    if [[ -n "$SAVED_STTY" ]]; then
        stty "$SAVED_STTY" 2>/dev/null
    else
        stty sane 2>/dev/null
    fi
    if [[ -n "$DISPLAY_FILE" ]]; then
        rm -f "$DISPLAY_FILE" "${DISPLAY_FILE}.tmp" "${DISPLAY_FILE}.pid" "${DISPLAY_FILE}.pl" 2>/dev/null
    fi
    clear_screen
    printf 'radio: goodbye\n'
}

# ---------------------------------------------------------------------------
# Fuzzy match for direct play from CLI
# ---------------------------------------------------------------------------
fuzzy_match_station() {
    local query
    query=$(echo "$1" | tr '[:upper:]' '[:lower:]')
    local i

    for i in "${!STATION_NAMES[@]}"; do
        local name
        name=$(echo "${STATION_NAMES[$i]}" | tr '[:upper:]' '[:lower:]')
        if [[ "$name" == "$query" ]]; then
            echo "$i"
            return 0
        fi
    done

    for i in "${!STATION_NAMES[@]}"; do
        local name
        name=$(echo "${STATION_NAMES[$i]}" | tr '[:upper:]' '[:lower:]')
        if [[ "$name" == *"$query"* ]]; then
            echo "$i"
            return 0
        fi
    done

    return 1
}

print_station_list() {
    local current_category=""
    local i
    for i in "${!STATION_NAMES[@]}"; do
        if [[ "${STATION_CATEGORIES[$i]}" != "$current_category" ]]; then
            current_category="${STATION_CATEGORIES[$i]}"
            printf '\n%s%s%s\n' "${BOLD}" "$current_category" "${RESET}"
        fi
        printf '  %-36s %s%-10s%s  %s\n' \
            "${STATION_NAMES[$i]}" \
            "${DIM}" "${STATION_QUALITY[$i]}" "${RESET}" \
            "${STATION_DESCS[$i]}"
    done
    printf '\n'
}

# ---------------------------------------------------------------------------
# Direct play mode (non-interactive, uses ffplay)
# ---------------------------------------------------------------------------
direct_play() {
    local index="$1"
    local name="${STATION_NAMES[$index]}"
    local quality="${STATION_QUALITY[$index]}"
    local url="${STATION_URLS[$index]}"

    printf '%sPlaying:%s %s  %s[%s]%s\n' \
        "${BOLD}" "${RESET}" "$name" "${DIM}" "$quality" "${RESET}"
    printf '%sPress Ctrl+C to stop%s\n' "${DIM}" "${RESET}"

    trap 'printf "\n"; exit 0' INT TERM
    ffplay -nodisp -loglevel quiet "$url" 2>/dev/null
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------
main() {
    if ! command -v ffmpeg &>/dev/null; then
        printf 'radio: ffmpeg not found. Install ffmpeg first.\n' >&2
        printf '  brew install ffmpeg\n' >&2
        exit 1
    fi

    build_category_list

    if [[ "$1" == "--list" || "$1" == "-l" ]]; then
        print_station_list
        exit 0
    fi

    if [[ "$1" == "--help" || "$1" == "-h" ]]; then
        printf 'Usage: radio [station-name | --list | --help]\n\n'
        printf 'Interactive terminal radio player.\n\n'
        printf 'Options:\n'
        printf '  (no args)       Launch interactive TUI\n'
        printf '  <station-name>  Play station directly (fuzzy match)\n'
        printf '  --list, -l      List all available stations\n'
        printf '  --help, -h      Show this help message\n'
        exit 0
    fi

    if [[ -n "$1" ]]; then
        local match
        match=$(fuzzy_match_station "$*")
        if [[ $? -eq 0 && -n "$match" ]]; then
            direct_play "$match"
            exit 0
        else
            printf 'radio: no station matching "%s"\n' "$*" >&2
            printf 'Try: radio --list\n' >&2
            exit 1
        fi
    fi

    DISPLAY_FILE=$(mktemp /tmp/radio_wave.XXXXXX)
    WAVE_SCRIPT="${DISPLAY_FILE}.pl"
    printf '%s' '
        binmode(STDIN);
        my $df = $ARGV[0];
        my $spp = 120;
        my @tlf = (0,0x40,0x44,0x46,0x47);
        my @trf = (0,0x80,0xA0,0xB0,0xB8);
        my @blf = (0,0x01,0x03,0x07,0x47);
        my @brf = (0,0x08,0x18,0x38,0xB8);
        my $tbuf = "";
        my $bbuf = "";
        my @s;
        while (sysread(STDIN, my $raw, 4096)) {
            push @s, unpack("C*", $raw);
            my $changed = 0;
            while (@s >= $spp) {
                my @c = splice(@s, 0, $spp);
                my $h = int($spp / 2);
                my ($pl, $pr) = (0, 0);
                for (0..$h-1) { my $a = abs($c[$_]-128); $pl=$a if $a>$pl }
                for ($h..$#c) { my $a = abs($c[$_]-128); $pr=$a if $a>$pr }
                my $ll = int($pl*4/80); $ll=4 if $ll>4;
                my $rl = int($pr*4/80); $rl=4 if $rl>4;
                my $to = $tlf[$ll] + $trf[$rl];
                my $bo = $blf[$ll] + $brf[$rl];
                $tbuf .= chr(226).chr(160+int($to/64)).chr(128+($to%64));
                $bbuf .= chr(226).chr(160+int($bo/64)).chr(128+($bo%64));
                if (length($tbuf) > 600) { $tbuf = substr($tbuf, -600) }
                if (length($bbuf) > 600) { $bbuf = substr($bbuf, -600) }
                $changed = 1;
            }
            if ($changed) {
                if (open(my $fh, ">:raw", "$df.tmp")) {
                    print $fh $tbuf, "\n", $bbuf;
                    close($fh);
                    rename("$df.tmp", $df);
                }
            }
        }
    ' > "$WAVE_SCRIPT"

    trap cleanup EXIT
    trap 'RESIZE_PENDING=1' WINCH
    trap : ALRM
    (while kill -0 $$ 2>/dev/null; do sleep 0.03; kill -ALRM $$ 2>/dev/null; done) &
    TIMER_PID=$!

    SAVED_STTY=$(stty -g 2>/dev/null)
    stty -echo -icanon 2>/dev/null

    get_volume
    expand_current_category
    update_terminal_size
    calculate_vu_width
    hide_cursor
    clear_screen
    render

    while true; do
        check_playback
        if ! handle_input; then
            break
        fi
        if [[ $RESIZE_PENDING -eq 1 ]]; then
            RESIZE_PENDING=0
            update_terminal_size
            calculate_vu_width
            clear_screen
        fi
        render
    done
}

main "$@"
